{
  "manifest_version": 3,
  "name": "XPath 元素选择器",
  "version": "1.0.0",
  "description": "在任意网页上点选元素，生成并复制 XPath，支持三种模式与自动填充，面向内部数据采集场景",
  "icons": {
    "16": "images/icon16.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "images/icon16.png",
      "48": "images/icon48.png",
      "128": "images/icon128.png"
    }
  },
  "permissions": ["activeTab", "clipboardWrite"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["js/xpath-generator.js", "js/content.js"]
    }
  ],
  "background": {
    "service_worker": "js/background.js"
  }
}